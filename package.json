{
  "name": "stream-grid",
  "version": "1.0.0",
  "type": "module",
  "description": "Lightweight, zero-dependency ES6+ data table library with pluggable adapters, auto-switching client/server filtering, three pagination modes, a hook system, and a plugin API.",
  "main": "src/StreamGrid.js",
  "module": "src/StreamGrid.js",
  "exports": {
    ".": "./src/StreamGrid.js",
    "./utils": "./src/utils/html.js",
    "./dataAdapter/RestApiAdapter": "./src/dataAdapter/RestApiAdapter.js",
    "./dataAdapter/CacheAdapter": "./src/dataAdapter/CacheAdapter.js",
    "./dataAdapter/BaseDataAdapter": "./src/dataAdapter/BaseDataAdapter.js"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test:unit": "mocha tests/unit/run-unit-tests.mjs",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "build": "esbuild src/StreamGrid.js --bundle --format=esm --minify --sourcemap --outfile=dist/streamgrid.min.js",
    "build:iife": "esbuild src/StreamGrid.js --bundle --format=iife --global-name=StreamGrid --minify --sourcemap --outfile=dist/streamgrid.iife.min.js",
    "build:all": "npm run build && npm run build:iife",
    "serve:test": "json-server test-db.json --port 3000 --static .",
    "demo": "json-server test-db.json --port 3000 --static . --open /test-page.html"
  },
  "keywords": [
    "data-grid",
    "table",
    "vanilla-js",
    "es6",
    "pagination",
    "filtering"
  ],
  "author": "Mihai Lupu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mihai-r-lupu/streamgrid.git"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.52.0",
    "chai": "^5.2.0",
    "esbuild": "^0.27.4",
    "esm": "^3.2.25",
    "jsdom": "^26.1.0",
    "json-server": "^0.17.4",
    "mocha": "^10.2.0",
    "sinon": "^20.0.0"
  }
}
